{
  "command": "rust-analyzer",
  "args": [],
  "settings": {
    "rust-analyzer": {
      "checkOnSave": {
        "command": "clippy"
      },
      "cargo": {
        "allFeatures": true
      },
      "procMacro": {
        "enable": true
      },
      "inlayHints": {
        "enable": true
      }
    }
  }
}
